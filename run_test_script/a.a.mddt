# Compiler Paths (Optional)
compilers {
    NewEnv: "python"
}

# Global Environment Variables
env {
    DB_HOST: "localhost"
    PORT: "8080"
}

run "Bench-1" {
    file: "../python/bench/bench-1.py"
}

run "Bench-1" {
    file: "../JavaScript/bench/bench-1.js"
    env_PORT: "9090" # Overrides global PORT
}

run "Bench-1" {
    file: "../rust/src/bench/bench-1.rs"
}
